    "next": "^15.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@storybook/nextjs-vite": "^10.3.3",
    "@types/node": "^22.15.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.2.9",
    "postcss": "^8.5.3",
    "storybook": "^10.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
